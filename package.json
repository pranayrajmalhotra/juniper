{
  "name": "juniper-club",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i src/tailwind.css -o build/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i src/tailwind.css -o build/css/tailwind.css --watch",
    "build:html": "node build-site.mjs && node wire-buttons.mjs",
    "build": "npm run build:css && npm run build:html",
    "serve": "node dev-server.mjs",
    "dev": "npm run build && node dev-server.mjs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/forms": "^0.5.9",
    "tailwindcss": "^4.0.0"
  }
}
